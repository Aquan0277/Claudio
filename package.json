{
  "name": "ai-radio",
  "version": "1.0.0",
  "description": "Personal AI Radio Station powered by Claude",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "ncm": "node ncm-server/start.js",
    "local:start": "node scripts/local-start.js",
    "local:stop": "bash scripts/local-stop.sh",
    "local:restart": "npm run local:stop || true && npm run local:start",
    "local:status": "bash scripts/local-status.sh"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "node-cron": "^3.0.3",
    "uuid": "^14.0.0",
    "ws": "^8.16.0"
  }
}
