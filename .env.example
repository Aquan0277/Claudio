# Claudio local config
# Copy this file to .env and fill in your own credentials.

# Server
PORT=8080

# NeteaseCloudMusicApi. server.js starts the bundled API automatically on this port.
NCM_API=http://localhost:3001

# Claude / Anthropic-compatible API
CLAUDE_MODE=api
API_BASE_URL=https://api.anthropic.com
API_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# Volcengine TTS
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=
VOLC_VOICE_ID=BV701_streaming

# Amap weather
AMAP_WEATHER_KEY=
WEATHER_CITY=440300
